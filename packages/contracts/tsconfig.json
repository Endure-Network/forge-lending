{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "esModuleInterop": true,
    "strict": true,
    "outDir": "typechain-types",
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "include": ["tests/hardhat/**/*", "deploy/**/*", "hardhat.config.ts"],
  "files": ["hardhat.config.ts"]
}
